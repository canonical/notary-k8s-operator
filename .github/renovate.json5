{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "https://raw.githubusercontent.com/canonical/identity-credentials-workflows/refs/heads/v0/renovate.json5",
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: grafana_k8s\\.grafana_dashboard[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "grafana_k8s.grafana_dashboard",
      datasourceTemplate: "custom.charmhub-grafana-dashboard",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: loki_k8s\\.loki_push_api[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "loki_k8s.loki_push_api",
      datasourceTemplate: "custom.charmhub-loki-push-api",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: prometheus_k8s\\.prometheus_scrape[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "prometheus_k8s.prometheus_scrape",
      datasourceTemplate: "custom.charmhub-prometheus-scrape",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: tempo_coordinator_k8s\\.charm_tracing[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "tempo_coordinator_k8s.charm_tracing",
      datasourceTemplate: "custom.charmhub-tempo-charm-tracing",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: tempo_coordinator_k8s\\.tracing[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "tempo_coordinator_k8s.tracing",
      datasourceTemplate: "custom.charmhub-tempo-tracing",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: traefik_k8s\\.ingress[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "traefik_k8s.ingress",
      datasourceTemplate: "custom.charmhub-traefik-ingress",
      versioningTemplate: "loose",
    },
  ],
  customDatasources: {
    "charmhub-grafana-dashboard": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/grafana-k8s/c49eb9c7dfef40c7b6235ebd67010a3f?api=0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
    "charmhub-loki-push-api": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/loki-k8s/bf76f23cdd03464b877c52bd1d2f563e?api=1",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
    "charmhub-prometheus-scrape": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/prometheus-k8s/bc84295fef5f4049878f07b131968ee2?api=0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
    "charmhub-tempo-charm-tracing": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/tempo-coordinator-k8s/01780f1e588c42c3976d26780fdf9b89?api=0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
    "charmhub-tempo-tracing": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/tempo-coordinator-k8s/d2f02b1f8d1244b5989fd55bc3a28943?api=0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
    "charmhub-traefik-ingress": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/traefik-k8s/e6de2a5cd5b34422a204668f3b8f90d2?api=2",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
  },
}
